generator client {
  provider = "prisma-client-js" 
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppRole {
  ADMIN
  CONTROLLER
  SALES
}

model Application {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  firstName          String?
  lastName           String?
  phone              String?
  email              String?

  identityType       String?
  identityValue      String?
  issuingCountry     String?
  identityStatus     String?

  stockNumber        String?
  vin                String?
  vehicleYear        Int?
  vehicleMake        String?
  vehicleModel       String?
  vehiclePrice       Float?

  downPayment        Float?
  tradeIn            Float?
  amountFinanced     Float?

  creditScore        Int?
  monthlyIncome      Float?

  status             String?  @default("DRAFT")
  lender             String?
  tier               String?
  maxPayment         Float?
  maxVehicle         Float?
  decisionReason     String?
  dealStrength       Int?

  fundingDate        DateTime?
  fundingAmount      Float?
}

model InventoryUnit {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  stockNumber     String   @unique
  vin             String?  @unique
  year            Int?
  make            String?
  model           String?
  trim            String?
  price           Float?
  mileage         Int?

  bodyStyle       String? 
  exteriorColor   String?
  interiorColor   String?

  isAvailable     Boolean  @default(true)

  minCreditScore  Int?
  maxAdvance      Float?   @default(1.15)
  featuredRank    Int?     @default(0)

  @@index([isAvailable])
  @@index([make, model])
  @@index([price])
  @@index([minCreditScore])
}
