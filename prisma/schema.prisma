generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Application {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Applicant
  firstName      String?
  lastName       String?
  email          String?
  phone          String?

  // Vehicle / inventory
  stockNumber    String?
  vin            String?
  vehicleYear    Int?
  vehicleMake    String?
  vehicleModel   String?
  vehiclePrice   Float?

  // Deal structure
  downPayment    Float?
  tradeIn        Float?
  amountFinanced Float?

  // Credit / income
  creditScore    Int?
  monthlyIncome  Float?

  // Workflow
  status         String   @default("PENDING")

  // Underwriting outputs
  tier           String?
  lender         String?
  maxPayment     Float?
  maxVehicle     Float?
  decisionReason String?
}
