generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SALES
}

model Team {
  id           String        @id @default(cuid())
  name         String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  users        User[]
  applications Application[]
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  fullName     String
  passwordHash String
  role         UserRole      @default(SALES)
  teamId       String?
  team         Team?         @relation(fields: [teamId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  applications Application[] @relation("OwnerApplications")
}

model Application {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Ownership / visibility
  ownerId        String?
  owner          User?    @relation("OwnerApplications", fields: [ownerId], references: [id])
  teamId         String?
  team           Team?    @relation(fields: [teamId], references: [id])

  // Applicant
  firstName      String?
  lastName       String?
  email          String?
  phone          String?

  // Vehicle / inventory
  stockNumber    String?
  vin            String?
  vehicleYear    Int?
  vehicleMake    String?
  vehicleModel   String?
  vehiclePrice   Float?

  // Deal structure
  downPayment    Float?
  tradeIn        Float?
  amountFinanced Float?

  // Credit / income
  creditScore    Int?
  monthlyIncome  Float?

  // Workflow
  status         String   @default("PENDING")

  // Underwriting outputs
  tier           String?
  lender         String?
  maxPayment     Float?
  maxVehicle     Float?
  decisionReason String?
}
