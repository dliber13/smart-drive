generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppRole {
  ADMIN
  CONTROLLER
  SALES
}

model Application {
  id                 String          @id @default(cuid())
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  firstName          String?
  lastName           String?
  phone              String?
  email              String?

  identityType       String?
  identityValue      String?
  issuingCountry     String?
  identityStatus     String?

  stockNumber        String?
  vin                String?
  vehicleYear        Int?
  vehicleMake        String?
  vehicleModel       String?
  vehiclePrice       Float?

  downPayment        Float?
  tradeIn            Float?
  amountFinanced     Float?

  creditScore        Int?
  monthlyIncome      Float?

  status             String?         @default("DRAFT")
  lender             String?
  tier               String?
  maxPayment         Float?
  maxVehicle         Float?
  decisionReason     String?
  dealStrength       Int?

  fundingDate        DateTime?
  fundingAmount      Float?
  lenderConfirmation String?

  statusHistory      StatusHistory[]
}

model Vehicle {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  stockNumber   String   @unique
  year          Int?
  make          String?
  model         String?

  mileage       Int?
  dateInStock   DateTime?

  askingPrice   Float?
  totalCost     Float?

  jdTrade       Float?
  jdRetail      Float?
}

model StatusHistory {
  id            String      @id @default(cuid())
  createdAt     DateTime    @default(now())

  applicationId String
  fromStatus    String?
  toStatus      String
  note          String?

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model User {
  id           String   @id
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  email        String   @unique
  passwordHash String
  role         AppRole

  firstName    String?
  lastName     String?
}
