model Application {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  // EXISTING CORE FIELDS
  firstName     String
  lastName      String

  // 🔐 IDENTITY SYSTEM (NEW)
  identityType  IdentityType
  identityValue String
  issuingCountry String?
  identityStatus IdentityStatus @default(PENDING)

  // RELATION
  ownerId String?
}

enum IdentityType {
  SSN
  ITIN
  PASSPORT
  MATRICULA
  OTHER
}

enum IdentityStatus {
  PENDING
  VERIFIED
  REJECTED
}
