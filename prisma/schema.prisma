model InventoryUnit {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  stockNumber     String   @unique
  vin             String?  @unique
  year            Int?
  make            String?
  model           String?
  trim            String?
  price           Float?
  mileage         Int?

  bodyStyle       String?
  exteriorColor   String?
  interiorColor   String?

  isAvailable     Boolean  @default(true)

  minCreditScore  Int?
  maxAdvance      Float?   @default(1.15)
  featuredRank    Int?     @default(0)

  @@index([isAvailable])
  @@index([make, model])
  @@index([price])
  @@index([minCreditScore])
}
